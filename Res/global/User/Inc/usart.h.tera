#ifndef USART_H
#define USART_H

{% if usart is defined and usart | length > 0 -%}
{%- for usart_item in usart -%}
{%- for usart_name, cfg in usart_item -%}
void {{ usart_name | replace(from="USART", to="UART") }}_UART_Init(void);
{%- endfor %}
{%- endfor %}
{%- endif %}

#endif //USART_H
