{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "CH32L103 运行时配置 Schema（Draft-07）。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_name",
    "contexts"
  ],
  "properties": {
    "model_name": {
      "description": "目标型号名称，固定为 ch32l103。",
      "type": "string",
      "const": "ch32l103"
    },
    "contexts": {
      "description": "运行时上下文配置集合。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mcu",
        "clock",
        "linker"
      ],
      "properties": {
        "mcu": {
          "description": "芯片工程与启动文件配置。",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "project_name",
            "startup_file"
          ],
          "properties": {
            "project_name": {
              "description": "工程名称。",
              "type": "string",
              "minLength": 2
            },
            "startup_file": {
              "description": "启动汇编文件名（枚举锁定）。",
              "type": "string",
              "enum": [
                "startup_ch32l103.S"
              ]
            }
          }
        },
        "clock": {
          "description": "时钟配置。",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "clock_source",
            "pll_source",
            "hse_freq_mhz",
            "pll_mul"
          ],
          "properties": {
            "clock_source": {
              "description": "系统时钟源：HSE 或 HSI。",
              "type": "string",
              "enum": [
                "HSE",
                "HSI"
              ]
            },
            "pll_source": {
              "description": "PLL 输入源配置宏。",
              "type": "string",
              "enum": [
                "RCC_PLLSource_HSE_Div1",
                "RCC_PLLSource_HSE_Div2",
                "RCC_PLLSource_HSI_Div2"
              ]
            },
            "hse_freq_mhz": {
              "description": "外部高速晶振频率（MHz）。",
              "type": "integer",
              "minimum": 3,
              "maximum": 25
            },
            "pll_mul": {
              "description": "PLL 倍频系数。最小值 1；当时钟源为 HSE 时最大 16，当时钟源为 HSI 时最大 12。",
              "type": "integer",
              "minimum": 1
            }
          },
          "allOf": [
            {
              "if": {
                "required": [
                  "clock_source"
                ],
                "properties": {
                  "clock_source": {
                    "const": "HSE"
                  }
                }
              },
              "then": {
                "properties": {
                  "pll_source": {
                    "enum": [
                      "RCC_PLLSource_HSE_Div1",
                      "RCC_PLLSource_HSE_Div2"
                    ]
                  },
                  "pll_mul": {
                    "maximum": 16
                  }
                }
              }
            },
            {
              "if": {
                "required": [
                  "clock_source"
                ],
                "properties": {
                  "clock_source": {
                    "const": "HSI"
                  }
                }
              },
              "then": {
                "properties": {
                  "pll_source": {
                    "const": "RCC_PLLSource_HSI_Div2"
                  },
                  "pll_mul": {
                    "maximum": 12
                  }
                }
              }
            }
          ]
        },
        "linker": {
          "description": "链接脚本相关配置。",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "flash_size",
            "ram_size",
            "stack_size"
          ],
          "properties": {
            "flash_size": {
              "description": "Flash 大小（KB）。",
              "type": "integer",
              "enum": [
                32,
                64
              ]
            },
            "ram_size": {
              "description": "RAM 大小（KB）。",
              "type": "integer",
              "enum": [
                10,
                20
              ]
            },
            "stack_size": {
              "description": "栈大小（字节）。",
              "type": "integer",
              "minimum": 128,
              "maximum": 8192
            }
          }
        },
        "usart": {
          "description": "USART 配置列表（可选）。字段不存在时表示不启用；若字段存在，至少包含 1 个元素。",
          "type": "array",
          "minItems": 1,
          "items": {
            "description": "单个数组项可包含一个或多个 USARTx 键（USART1~USART4）。",
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "patternProperties": {
              "^USART[1-4]$": {
                "description": "单个 USARTx 的配置对象。",
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "tx_pin",
                  "rx_pin",
                  "tx_port",
                  "rx_port",
                  "baud_rate",
                  "word_length",
                  "stop_bits",
                  "parity",
                  "hardware_flow_control",
                  "remap"
                ],
                "properties": {
                  "tx_pin": {
                    "description": "发送引脚；null 表示不使用发送。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "rx_pin": {
                    "description": "接收引脚；null 表示不使用接收。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "tx_port": {
                    "description": "TX 使用的 GPIO 端口名，例如 GPIOA。",
                    "type": "string",
                    "minLength": 1
                  },
                  "rx_port": {
                    "description": "RX 使用的 GPIO 端口名，例如 GPIOA。",
                    "type": "string",
                    "minLength": 1
                  },
                  "baud_rate": {
                    "description": "波特率（bps）。",
                    "type": "integer",
                    "minimum": 46,
                    "maximum": 6000000
                  },
                  "word_length": {
                    "description": "字长配置。",
                    "type": "integer",
                    "minimum": 1
                  },
                  "stop_bits": {
                    "description": "停止位配置。",
                    "type": "integer",
                    "minimum": 1
                  },
                  "parity": {
                    "description": "校验位配置；null 表示不启用。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "hardware_flow_control": {
                    "description": "硬件流控开关。",
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "cts",
                      "rts"
                    ],
                    "properties": {
                      "cts": {
                        "description": "是否启用 CTS。",
                        "type": "boolean"
                      },
                      "rts": {
                        "description": "是否启用 RTS。",
                        "type": "boolean"
                      }
                    }
                  },
                  "remap": {
                    "description": "引脚重映射宏；null 表示不重映射。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "irq": {
                    "description": "USART 中断事件列表（严格按 USART_ITConfig 注释支持项）。空列表表示不启用中断。",
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": [
                        "USART_IT_PE",
                        "USART_IT_TXE",
                        "USART_IT_TC",
                        "USART_IT_RXNE",
                        "USART_IT_IDLE",
                        "USART_IT_LBD",
                        "USART_IT_ERR"
                      ]
                    }
                  }
                },
                "anyOf": [
                  {
                    "properties": {
                      "tx_pin": {
                        "type": "string"
                      }
                    }
                  },
                  {
                    "properties": {
                      "rx_pin": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            },
            "allOf": [
              {
                "if": {
                  "required": [
                    "USART1"
                  ]
                },
                "then": {
                  "properties": {
                    "USART1": {
                      "description": "USART1 引脚映射约束：按 remap 联动限制 TX/RX 与端口。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_9"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_10"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap1_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_6"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_7"
                              },
                              "tx_port": {
                                "const": "GPIOB"
                              },
                              "rx_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap2_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_4"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_5"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap3_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_5"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_4"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap4_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_9"
                              },
                              "tx_port": {
                                "const": "GPIOB"
                              },
                              "rx_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_FullRemap_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_12"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_12"
                              },
                              "tx_port": {
                                "const": "GPIOB"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "description": "USART1 可用重映射宏或 null。",
                          "enum": [
                            null,
                            "GPIO_PartialRemap1_USART1",
                            "GPIO_PartialRemap2_USART1",
                            "GPIO_PartialRemap3_USART1",
                            "GPIO_PartialRemap4_USART1",
                            "GPIO_FullRemap_USART1"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "USART2"
                  ]
                },
                "then": {
                  "properties": {
                    "USART2": {
                      "description": "USART2 引脚映射约束：按 remap 联动限制 TX/RX 与端口。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_2"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_3"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap1_USART2"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_12"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "enum": [
                                  "GPIO_PartialRemap2_USART2",
                                  "GPIO_FullRemap_USART2"
                                ]
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_12"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "description": "USART2 可用重映射宏或 null。",
                          "enum": [
                            null,
                            "GPIO_PartialRemap1_USART2",
                            "GPIO_PartialRemap2_USART2",
                            "GPIO_FullRemap_USART2"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "USART3"
                  ]
                },
                "then": {
                  "properties": {
                    "USART3": {
                      "description": "USART3 引脚映射约束：按 remap 联动限制 TX/RX 与端口。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_10"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "tx_port": {
                                "const": "GPIOB"
                              },
                              "rx_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap_USART3"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_1"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_0"
                              },
                              "tx_port": {
                                "const": "GPIOD"
                              },
                              "rx_port": {
                                "const": "GPIOD"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_FullRemap_USART3"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_0"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_1"
                              },
                              "tx_port": {
                                "const": "GPIOD"
                              },
                              "rx_port": {
                                "const": "GPIOD"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "description": "USART3 可用重映射宏或 null。",
                          "enum": [
                            null,
                            "GPIO_PartialRemap_USART3",
                            "GPIO_FullRemap_USART3"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "USART4"
                  ]
                },
                "then": {
                  "properties": {
                    "USART4": {
                      "description": "USART4 引脚映射约束：默认映射或 GPIO_Remap_USART4。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_0"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_1"
                              },
                              "tx_port": {
                                "const": "GPIOB"
                              },
                              "rx_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_Remap_USART4"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_5"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_5"
                              },
                              "tx_port": {
                                "const": "GPIOA"
                              },
                              "rx_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "enum": [
                            null,
                            "GPIO_Remap_USART4"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        },
        "i2c": {
          "description": "I2C 配置列表（可选）。字段不存在时表示不启用；若字段存在，至少包含 1 个元素。",
          "type": "array",
          "minItems": 1,
          "items": {
            "description": "单个数组项可包含一个或多个 I2Cx 键（I2C1~I2C2）。",
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "patternProperties": {
              "^I2C[1-2]$": {
                "description": "单个 I2Cx 的配置对象。",
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "scl_port",
                  "scl_pin",
                  "sda_port",
                  "sda_pin",
                  "smba_port",
                  "smba_pin",
                  "clock_speed_khz",
                  "mode",
                  "duty_cycle",
                  "own_address",
                  "ack",
                  "acknowledged_address",
                  "remap"
                ],
                "properties": {
                  "scl_port": {
                    "description": "I2C SCL 使用的 GPIO 端口名。",
                    "type": "string",
                    "enum": [
                      "GPIOA",
                      "GPIOB"
                    ]
                  },
                  "scl_pin": {
                    "description": "I2C SCL 引脚宏。",
                    "type": "string",
                    "enum": [
                      "GPIO_Pin_6",
                      "GPIO_Pin_9",
                      "GPIO_Pin_10",
                      "GPIO_Pin_13"
                    ]
                  },
                  "sda_port": {
                    "description": "I2C SDA 使用的 GPIO 端口名。",
                    "type": "string",
                    "enum": [
                      "GPIOA",
                      "GPIOB"
                    ]
                  },
                  "sda_pin": {
                    "description": "I2C SDA 引脚宏。",
                    "type": "string",
                    "enum": [
                      "GPIO_Pin_7",
                      "GPIO_Pin_11",
                      "GPIO_Pin_12"
                    ]
                  },
                  "smba_port": {
                    "description": "I2C SMBA 使用的 GPIO 端口名。",
                    "type": "string",
                    "enum": [
                      "GPIOB"
                    ]
                  },
                  "smba_pin": {
                    "description": "I2C SMBA 引脚宏。",
                    "type": "string",
                    "enum": [
                      "GPIO_Pin_5",
                      "GPIO_Pin_12"
                    ]
                  },
                  "clock_speed_khz": {
                    "description": "I2C 时钟（kHz），支持标准模式/快速模式。",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 400
                  },
                  "mode": {
                    "description": "I2C 工作模式。",
                    "type": "string",
                    "enum": [
                      "I2C_Mode_I2C",
                      "I2C_Mode_SMBusDevice",
                      "I2C_Mode_SMBusHost"
                    ]
                  },
                  "duty_cycle": {
                    "description": "快速模式占空比。",
                    "type": "string",
                    "enum": [
                      "I2C_DutyCycle_2",
                      "I2C_DutyCycle_16_9"
                    ]
                  },
                  "own_address": {
                    "description": "本机地址，十六进制字符串。",
                    "type": "string",
                    "pattern": "^0x[0-9A-Fa-f]{1,4}$"
                  },
                  "ack": {
                    "description": "是否启用 ACK。",
                    "type": "boolean"
                  },
                  "acknowledged_address": {
                    "description": "地址位宽：7 或 10。",
                    "type": "integer",
                    "enum": [
                      7,
                      10
                    ]
                  },
                  "remap": {
                    "description": "I2C 引脚重映射宏；null 表示默认映射。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "irq": {
                    "description": "I2C 事件中断列表（EV IRQ）。空列表表示不启用。",
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": [
                        "I2C_IT_BUF",
                        "I2C_IT_EVT",
                        "I2C_IT_TXE",
                        "I2C_IT_RXNE",
                        "I2C_IT_STOPF",
                        "I2C_IT_ADD10",
                        "I2C_IT_BTF",
                        "I2C_IT_ADDR",
                        "I2C_IT_SB"
                      ]
                    }
                  },
                  "error_event": {
                    "description": "I2C 错误中断事件列表（ER IRQ）。空列表表示不启用。",
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": [
                        "I2C_IT_SMBALERT",
                        "I2C_IT_TIMEOUT",
                        "I2C_IT_PECERR",
                        "I2C_IT_OVR",
                        "I2C_IT_AF",
                        "I2C_IT_ARLO",
                        "I2C_IT_BERR"
                      ]
                    }
                  }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "required": [
                    "I2C1"
                  ]
                },
                "then": {
                  "properties": {
                    "I2C1": {
                      "description": "I2C1 引脚映射约束：按 remap 联动限制 SCL/SDA；SMBA 恒为 PB5。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "scl_port": {
                                "const": "GPIOB"
                              },
                              "scl_pin": {
                                "const": "GPIO_Pin_6"
                              },
                              "sda_port": {
                                "const": "GPIOB"
                              },
                              "sda_pin": {
                                "const": "GPIO_Pin_7"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap1_I2C1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "scl_port": {
                                "const": "GPIOA"
                              },
                              "scl_pin": {
                                "const": "GPIO_Pin_13"
                              },
                              "sda_port": {
                                "const": "GPIOA"
                              },
                              "sda_pin": {
                                "const": "GPIO_Pin_12"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_FullRemap_I2C1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "scl_port": {
                                "const": "GPIOB"
                              },
                              "scl_pin": {
                                "const": "GPIO_Pin_9"
                              },
                              "sda_port": {
                                "const": "GPIOB"
                              },
                              "sda_pin": {
                                "const": "GPIO_Pin_11"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "smba_port": {
                          "const": "GPIOB"
                        },
                        "smba_pin": {
                          "const": "GPIO_Pin_5"
                        },
                        "remap": {
                          "enum": [
                            null,
                            "GPIO_PartialRemap1_I2C1",
                            "GPIO_FullRemap_I2C1"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "I2C2"
                  ]
                },
                "then": {
                  "properties": {
                    "I2C2": {
                      "description": "I2C2 当前仅支持默认映射（SCL/PB10，SDA/PB11，SMBA/PB12）。",
                      "properties": {
                        "scl_port": {
                          "const": "GPIOB"
                        },
                        "scl_pin": {
                          "const": "GPIO_Pin_10"
                        },
                        "sda_port": {
                          "const": "GPIOB"
                        },
                        "sda_pin": {
                          "const": "GPIO_Pin_11"
                        },
                        "smba_port": {
                          "const": "GPIOB"
                        },
                        "smba_pin": {
                          "const": "GPIO_Pin_12"
                        },
                        "remap": {
                          "enum": [
                            null
                          ]
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  }
}
