{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "CH32L103 运行时配置 Schema（Draft-07）。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_name",
    "contexts"
  ],
  "properties": {
    "model_name": {
      "description": "目标型号名称，固定为 ch32l103。",
      "type": "string",
      "const": "ch32l103"
    },
    "contexts": {
      "description": "运行时上下文配置集合。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mcu",
        "clock",
        "linker"
      ],
      "properties": {
        "mcu": {
          "description": "芯片工程与启动文件配置。",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "project_name",
            "startup_file"
          ],
          "properties": {
            "project_name": {
              "description": "工程名称。",
              "type": "string",
              "minLength": 2
            },
            "startup_file": {
              "description": "启动汇编文件名（枚举锁定）。",
              "type": "string",
              "enum": [
                "startup_ch32l103.S"
              ]
            }
          }
        },
        "clock": {
          "description": "时钟配置。",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "clock_source",
            "pll_source",
            "hse_freq_mhz",
            "pll_mul"
          ],
          "properties": {
            "clock_source": {
              "description": "系统时钟源：HSE 或 HSI。",
              "type": "string",
              "enum": [
                "HSE",
                "HSI"
              ]
            },
            "pll_source": {
              "description": "PLL 输入源配置宏。",
              "type": "string",
              "enum": [
                "RCC_PLLSource_HSE_Div1",
                "RCC_PLLSource_HSE_Div2",
                "RCC_PLLSource_HSI_Div2"
              ]
            },
            "hse_freq_mhz": {
              "description": "外部高速晶振频率（MHz）。",
              "type": "integer",
              "minimum": 3,
              "maximum": 25
            },
            "pll_mul": {
              "description": "PLL 倍频系数。最小值 1；当时钟源为 HSE 时最大 16，当时钟源为 HSI 时最大 12。",
              "type": "integer",
              "minimum": 1
            }
          },
          "allOf": [
            {
              "if": {
                "required": [
                  "clock_source"
                ],
                "properties": {
                  "clock_source": {
                    "const": "HSE"
                  }
                }
              },
              "then": {
                "properties": {
                  "pll_source": {
                    "enum": [
                      "RCC_PLLSource_HSE_Div1",
                      "RCC_PLLSource_HSE_Div2"
                    ]
                  },
                  "pll_mul": {
                    "maximum": 16
                  }
                }
              }
            },
            {
              "if": {
                "required": [
                  "clock_source"
                ],
                "properties": {
                  "clock_source": {
                    "const": "HSI"
                  }
                }
              },
              "then": {
                "properties": {
                  "pll_source": {
                    "const": "RCC_PLLSource_HSI_Div2"
                  },
                  "pll_mul": {
                    "maximum": 12
                  }
                }
              }
            }
          ]
        },
        "linker": {
          "description": "链接脚本相关配置。",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "flash_size",
            "ram_size",
            "stack_size"
          ],
          "properties": {
            "flash_size": {
              "description": "Flash 大小（KB）。",
              "type": "integer",
              "enum": [
                32,
                64
              ]
            },
            "ram_size": {
              "description": "RAM 大小（KB）。",
              "type": "integer",
              "enum": [
                10,
                20
              ]
            },
            "stack_size": {
              "description": "栈大小（字节）。",
              "type": "integer",
              "minimum": 128,
              "maximum": 8192
            }
          }
        },
        "usart": {
          "description": "USART 配置列表（可选）。字段不存在时表示不启用；若字段存在，至少包含 1 个元素。",
          "type": "array",
          "minItems": 1,
          "items": {
            "description": "单个数组项可包含一个或多个 USARTx 键（USART1~USART4）。",
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "patternProperties": {
              "^USART[1-4]$": {
                "description": "单个 USARTx 的配置对象。",
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "tx_pin",
                  "rx_pin",
                  "gpio_port",
                  "baud_rate",
                  "word_length",
                  "stop_bits",
                  "parity",
                  "hardware_flow_control",
                  "remap"
                ],
                "properties": {
                  "tx_pin": {
                    "description": "发送引脚；null 表示不使用发送。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "rx_pin": {
                    "description": "接收引脚；null 表示不使用接收。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "gpio_port": {
                    "description": "GPIO 端口名，例如 GPIOA。",
                    "type": "string",
                    "minLength": 1
                  },
                  "baud_rate": {
                    "description": "波特率（bps）。",
                    "type": "integer",
                    "minimum": 46,
                    "maximum": 6000000
                  },
                  "word_length": {
                    "description": "字长配置。",
                    "type": "integer",
                    "minimum": 1
                  },
                  "stop_bits": {
                    "description": "停止位配置。",
                    "type": "integer",
                    "minimum": 1
                  },
                  "parity": {
                    "description": "校验位配置；null 表示不启用。",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "hardware_flow_control": {
                    "description": "硬件流控开关。",
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "cts",
                      "rts"
                    ],
                    "properties": {
                      "cts": {
                        "description": "是否启用 CTS。",
                        "type": "boolean"
                      },
                      "rts": {
                        "description": "是否启用 RTS。",
                        "type": "boolean"
                      }
                    }
                  },
                  "remap": {
                    "description": "引脚重映射宏；null 表示不重映射。",
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "anyOf": [
                  {
                    "properties": {
                      "tx_pin": {
                        "type": "string"
                      }
                    }
                  },
                  {
                    "properties": {
                      "rx_pin": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            },
            "allOf": [
              {
                "if": {
                  "required": [
                    "USART1"
                  ]
                },
                "then": {
                  "properties": {
                    "USART1": {
                      "description": "USART1 引脚映射约束：按 remap 联动限制 TX/RX 与端口。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_9"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_10"
                              },
                              "gpio_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap1_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_6"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_7"
                              },
                              "gpio_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap2_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_4"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_5"
                              },
                              "gpio_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap3_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_5"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_4"
                              },
                              "gpio_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap4_USART1"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_9"
                              },
                              "gpio_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "description": "USART1 可用重映射宏或 null。当前 schema 仅允许 TX/RX 同端口映射。",
                          "enum": [
                            null,
                            "GPIO_PartialRemap1_USART1",
                            "GPIO_PartialRemap2_USART1",
                            "GPIO_PartialRemap3_USART1",
                            "GPIO_PartialRemap4_USART1"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "USART2"
                  ]
                },
                "then": {
                  "properties": {
                    "USART2": {
                      "description": "USART2 引脚映射约束：按 remap 联动限制 TX/RX 与端口。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_2"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_3"
                              },
                              "gpio_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap1_USART2"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_12"
                              },
                              "gpio_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "enum": [
                                  "GPIO_PartialRemap2_USART2",
                                  "GPIO_FullRemap_USART2"
                                ]
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_12"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "gpio_port": {
                                "const": "GPIOA"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "description": "USART2 可用重映射宏或 null。",
                          "enum": [
                            null,
                            "GPIO_PartialRemap1_USART2",
                            "GPIO_PartialRemap2_USART2",
                            "GPIO_FullRemap_USART2"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "USART3"
                  ]
                },
                "then": {
                  "properties": {
                    "USART3": {
                      "description": "USART3 引脚映射约束：按 remap 联动限制 TX/RX 与端口。",
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": null
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_10"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_11"
                              },
                              "gpio_port": {
                                "const": "GPIOB"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_PartialRemap_USART3"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_1"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_0"
                              },
                              "gpio_port": {
                                "const": "GPIOD"
                              }
                            }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "remap": {
                                "const": "GPIO_FullRemap_USART3"
                              }
                            }
                          },
                          "then": {
                            "properties": {
                              "tx_pin": {
                                "const": "GPIO_Pin_0"
                              },
                              "rx_pin": {
                                "const": "GPIO_Pin_1"
                              },
                              "gpio_port": {
                                "const": "GPIOD"
                              }
                            }
                          }
                        }
                      ],
                      "properties": {
                        "remap": {
                          "description": "USART3 可用重映射宏或 null。",
                          "enum": [
                            null,
                            "GPIO_PartialRemap_USART3",
                            "GPIO_FullRemap_USART3"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "required": [
                    "USART4"
                  ]
                },
                "then": {
                  "properties": {
                    "USART4": {
                      "properties": {
                        "remap": {
                          "description": "USART4 当前仅支持默认映射。重映射模式下 TX/RX 分属不同端口，现有 gpio_port 单字段无法准确表达。",
                          "enum": [
                            null
                          ]
                        },
                        "tx_pin": {
                          "const": "GPIO_Pin_0"
                        },
                        "rx_pin": {
                          "const": "GPIO_Pin_1"
                        },
                        "gpio_port": {
                          "const": "GPIOB"
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  }
}
